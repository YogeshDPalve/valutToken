# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=vaulttoken:
REDIS_TLS=false

# ── Token Defaults ──────────────────────────────────────
DEFAULT_TOKEN_TTL=3600
DEFAULT_REFRESH_TTL=604800
DEFAULT_PURPOSE=local
DEFAULT_ISSUER=vaulttoken

# ── Key Management ──────────────────────────────────────
KEY_ROTATION_GRACE_PERIOD=86400
KEY_STORAGE=redis
KEY_FILE_PATH=./keys/keystore.json

# REQUIRED — 32 random bytes encoded as 64 hex characters
KEY_ENCRYPTION_SECRET=

# ── API Keys ────────────────────────────────────────────
API_KEYS=your-api-key:default
ADMIN_API_KEY=your-admin-key

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_ISSUE=20
RATE_LIMIT_VERIFY=100
RATE_LIMIT_REFRESH=10
RATE_LIMIT_REVOKE=20
RATE_LIMIT_WINDOW=60

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty
AUDIT_LOG_FILE=

# ── CORS ────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Implicit Assertions ─────────────────────────────────
IMPLICIT_ASSERTION_FIELDS=ip,ua
